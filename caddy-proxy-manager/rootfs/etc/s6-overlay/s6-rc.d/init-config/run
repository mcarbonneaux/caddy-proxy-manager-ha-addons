#!/usr/bin/with-contenv bashio

bashio::log.info "Reading add-on options..."

SESSION_SECRET=$(bashio::config 'session_secret')
if bashio::var.is_empty "${SESSION_SECRET}"; then
    if [ ! -f /data/.session_secret ]; then
        bashio::log.info "Generating random session_secret..."
        SESSION_SECRET=$(openssl rand -base64 32)
        echo "${SESSION_SECRET}" > /data/.session_secret
    else
        bashio::log.info "Loading session_secret from storage..."
        SESSION_SECRET=$(cat /data/.session_secret)
    fi
fi

ADMIN_USERNAME=$(bashio::config 'admin_username')
ADMIN_PASSWORD=$(bashio::config 'admin_password')
HTTP_PORT=$(bashio::config 'http_port')
HTTPS_PORT=$(bashio::config 'https_port')

# Validate required fields
if [ ${#SESSION_SECRET} -lt 32 ]; then
  bashio::exit.nok "session_secret must be at least 32 characters long"
fi
if bashio::var.is_empty "${ADMIN_PASSWORD}"; then
  bashio::exit.nok "admin_password must not be empty"
fi

# Write env vars for s6 child processes
export SESSION_SECRET
export ADMIN_USERNAME
export ADMIN_PASSWORD
export HTTP_PORT
export HTTPS_PORT
export DATABASE_URL="file:/data/db/caddy-proxy-manager.db"
export CADDY_API_URL="http://localhost:2019"
export PORT="3000"

printf "%s" "${SESSION_SECRET}"  > /var/run/s6/container_environment/SESSION_SECRET
printf "%s" "${ADMIN_USERNAME}"  > /var/run/s6/container_environment/ADMIN_USERNAME
printf "%s" "${ADMIN_PASSWORD}"  > /var/run/s6/container_environment/ADMIN_PASSWORD
printf "%s" "${HTTP_PORT}"       > /var/run/s6/container_environment/HTTP_PORT
printf "%s" "${HTTPS_PORT}"      > /var/run/s6/container_environment/HTTPS_PORT
printf "%s" "${DATABASE_URL}"    > /var/run/s6/container_environment/DATABASE_URL
printf "%s" "${CADDY_API_URL}"   > /var/run/s6/container_environment/CADDY_API_URL
printf "%s" "${PORT}"            > /var/run/s6/container_environment/PORT

# BASE_URL: use ingress URL if available, otherwise localhost
if bashio::var.has_value "$(bashio::addon.ingress_url 2>/dev/null)"; then
  BASE_URL=$(bashio::addon.ingress_url)
else
  BASE_URL="http://localhost:3000"
fi
export BASE_URL
printf "%s" "${BASE_URL}" > /var/run/s6/container_environment/BASE_URL

# Next.js specific: sometimes it needs environment variables in a .env file or specifically formatted
# though server.js usually picks up process.env.
# We'll stick to s6 environment for now but ensure SESSION_SECRET is definitely there.

bashio::log.info "Configuration loaded."
bashio::log.info "SESSION_SECRET length: ${#SESSION_SECRET}"
